{
  "name": "gigadoc-mcp",
  "version": "0.4.1",
  "description": "MCP server for Gigadoc-style Python documentation in Gigacode/Gemini/Qwen CLI.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "gigadoc-mcp": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "start": "node dist/src/index.js"
  },
  "keywords": [
    "mcp",
    "gigacode",
    "gemini",
    "qwen",
    "documentation",
    "python"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
